inShortThreshold = input.float(-0.65, "Short Threshold", step=0.01, group=groupScore)

// Session 5/6 Extensions
groupSx = "Session 5/6 Extensions"
inEnableMultiFVG = input.bool(true, "Enable Multi-FVG Registry", group=groupSx)
inMaxFVG = input.int(24, "Max Active/Tracked FVG", minval=4, maxval=100, group=groupSx)
inFVGBoxLife = input.int(220, "FVG Box Max Life Bars", minval=20, maxval=2000, group=groupSx)
inEnablePivotEventRows = input.bool(true, "Enable Pivot Event Rows", group=groupSx)
