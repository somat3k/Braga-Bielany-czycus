// -----------------------------
// [A] NEW INPUTS
// -----------------------------
groupS5 = "Session 5 Extensions"
inEnableMultiFVG = input.bool(true, "Enable Multi-FVG Registry", group=groupS5)
inMaxFVG = input.int(24, "Max Active/Tracked FVG", minval=4, maxval=100, group=groupS5)
inFVGBoxLife = input.int(220, "FVG Box Max Life Bars", minval=20, maxval=2000, group=groupS5)

inEnablePivotEventRows = input.bool(true, "Enable Pivot Event Rows", group=groupS5)
inPivotEventRows = input.int(8, "Pivot Event Rows", minval=2, maxval=25, group=groupS5)

inEnablePivotAnchors = input.bool(true, "Enable Pivot Anchors", group=groupS5)
inEnableFVGBoxes = input.bool(true, "Enable FVG Boxes", group=groupS5)

inEnableReliability = input.bool(true, "Enable Strategy Reliability Tracker", group=groupS5)
inRelLookback = input.int(120, "Reliability Lookback", minval=20, maxval=2000, group=groupS5)
inRelAlpha = input.float(0.12, "Reliability Update Alpha", minval=0.01, maxval=1.0, step=0.01, group=groupS5)
inRelMinWeightFactor = input.float(0.60, "Reliability Min Weight Factor", minval=0.1, maxval=1.0, step=0.05, group=groupS5)
inRelMaxWeightFactor = input.float(1.60, "Reliability Max Weight Factor", minval=1.0, maxval=3.0, step=0.05, group=groupS5)

// ---------- Reliability state ----------
var float relTrend=0.5, relMom=0.5, relVol=0.5, relStruct=0.5, relWave=0.5, relSmc=0.5
var int nTrend=0, nMom=0, nVol=0, nStruct=0, nWave=0, nSmc=0

fRelFactor(rel, n)=>
    trust = n >= inRelMinSamples ? 1.0 : fSafeDiv(n, inRelMinSamples, 1e-6)
    raw = inRelMinFactor + (inRelMaxFactor-inRelMinFactor)*rel
    1.0 + (raw-1.0)*trust

fRelDecay() =>
    if inRelEnable
        relTrend := fClamp(relTrend*(1.0-inRelDecay),0,1)
        relMom := fClamp(relMom*(1.0-inRelDecay),0,1)
        relVol := fClamp(relVol*(1.0-inRelDecay),0,1)
        relStruct := fClamp(relStruct*(1.0-inRelDecay),0,1)
        relWave := fClamp(relWave*(1.0-inRelDecay),0,1)
        relSmc := fClamp(relSmc*(1.0-inRelDecay),0,1)

// ============================================================
// Utility
// ============================================================

fClamp(v, lo, hi) => math.max(lo, math.min(hi, v))
fSafeDiv(a, b, eps) => a / (math.abs(b) < eps ? eps : b)
fNorm(v, scale) => fClamp(fSafeDiv(v, scale, 1e-6), -1.0, 1.0)
fNormRobust(v, center, spread, clampN) =>
    z = fSafeDiv(v - center, spread, 1e-6)
    fClamp(z / clampN, -1.0, 1.0)

fLineStyle(s) => s == "Dashed" ? line.style_dashed : s == "Dotted" ? line.style_dotted : line.style_solid

fColorBull() =>
    inTheme == "Nebula" ? color.rgb(0, 255, 170) :
     inTheme == "Monochrome Pro" ? color.rgb(220, 220, 220) :
     inTheme == "SMC Tactical" ? color.rgb(80, 220, 120) : color.rgb(60, 255, 200)
fColorBear() =>
    inTheme == "Nebula" ? color.rgb(255, 90, 180) :
     inTheme == "Monochrome Pro" ? color.rgb(120, 120, 120) :
     inTheme == "SMC Tactical" ? color.rgb(255, 110, 110) : color.rgb(255, 120, 70)
fColorNeutral() =>
    inTheme == "Nebula" ? color.rgb(130, 150, 255) :
     inTheme == "Monochrome Pro" ? color.rgb(180, 180, 180) :
     inTheme == "SMC Tactical" ? color.rgb(180, 200, 120) : color.rgb(140, 170, 255)

fSignalText(s) => s == SIG_LONG ? "LONG" : s == SIG_SHORT ? "SHORT" : "WAIT"
fRiskText(r) => r == RISK_LOW ? "LOW" : r == RISK_MED ? "MED" : "HIGH"
fRegimeText(r) => r == REGIME_TREND ? "TREND" : r == REGIME_RANGE ? "RANGE" : r == REGIME_VOLATILE ? "VOL" : "TRANS"

fPushInt(arr, v, n) =>
    array.unshift(arr, v)
    if array.size(arr) > n
        array.pop(arr)
fPushFloat(arr, v, n) =>
    array.unshift(arr, v)
    if array.size(arr) > n
        array.pop(arr)
fPushString(arr, v, n) =>
    array.unshift(arr, v)
    if array.size(arr) > n
        array.pop(arr)

// ============================================================
// State
// ============================================================

