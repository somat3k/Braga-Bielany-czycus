inEnableMAPack = input.bool(true, "Enable MA Pack", group=groupTrend)
inEnableVIDYA = input.bool(true, "Enable VIDYA", group=groupTrend)
inEnableVWAP = input.bool(true, "Enable VWAP", group=groupTrend)
