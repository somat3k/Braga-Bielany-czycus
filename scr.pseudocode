//@version=6
indicator("Pinacle Master Scaffold v6 • Session 6", overlay=true, max_lines_count=500, max_labels_count=500, max_boxes_count=400)

// ============================================================================
// S6 BLOCK 1/4
// FOUNDATION + INPUTS + CORE UTILITIES + GLOBAL STATE
// ----------------------------------------------------------------------------
// Goal:
// - Keep Session 4/5 design language
// - Compile-safe naming (no duplicate identifiers)
// - Prepare deterministic modules for S6
// ============================================================================

// ----------------------------------------------------------------------------
// [A] Constants
// ----------------------------------------------------------------------------
