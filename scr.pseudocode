MODE_MULTI_ENSEMBLE  = "MULTI_ENSEMBLE"
MODE_WEIGHTED        = "WEIGHTED_ENSEMBLE"

SIG_LONG  = 1
SIG_SHORT = -1
SIG_WAIT  = 0

REGIME_TREND      = 1
REGIME_RANGE      = 2
REGIME_VOLATILE   = 3
REGIME_TRANSITION = 4

RISK_LOW  = 1
RISK_MED  = 2
RISK_HIGH = 3

FVG_NONE    = 0
FVG_FRESH   = 1
FVG_PARTIAL = 2
FVG_FILLED  = 3
FVG_INVALID = 4

