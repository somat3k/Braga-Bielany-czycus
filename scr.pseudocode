inWSmc = input.float(1.30, "Weight SMC", step=0.05, group=groupScore)
inWAdaptiveQ = input.float(0.80, "Weight Adaptive Q", step=0.05, group=groupScore)
inConflictPenalty = input.float(0.15, "Conflict Penalty", step=0.01, minval=0.0, maxval=1.0, group=groupScore)
