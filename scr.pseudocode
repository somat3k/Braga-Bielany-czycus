inEnablePivotAnchors = input.bool(true, "Enable Pivot Anchors", group=groupSx)
inEnableFVGBoxes = input.bool(true, "Enable FVG Boxes", group=groupSx)
inEnableReliability = input.bool(true, "Enable Strategy Reliability Tracker", group=groupSx)
inRelLookback = input.int(120, "Reliability Lookback", minval=20, maxval=2000, group=groupSx)
inRelAlpha = input.float(0.12, "Reliability Update Alpha", minval=0.01, maxval=1.0, step=0.01, group=groupSx)
inRelMinWeightFactor = input.float(0.60, "Reliability Min Weight Factor", minval=0.1, maxval=1.0, step=0.05, group=groupSx)
inRelMaxWeightFactor = input.float(1.60, "Reliability Max Weight Factor", minval=1.0, maxval=3.0, step=0.05, group=groupSx)

// Display
groupVisual = "Visual/Table"
inShowVisual = input.bool(true, "Enable Visual Markers", group=groupVisual)
inShowDebug = input.bool(false, "Enable Debug Labels", group=groupVisual)
inTableRows = input.int(18, "Pivot Table Rows", minval=6, maxval=40, group=groupVisual)
inDrawBudget = input.int(240, "Draw Budget", minval=50, maxval=450, group=groupVisual)
inTheme = input.string("Nebula", "Theme", options=["Nebula", "Monochrome Pro", "SMC Tactical", "Aurora"], group=groupVisual)
inLineStyleSignal = input.string("Solid", "Signal Line Style", options=["Solid", "Dashed", "Dotted"], group=groupVisual)
inLineThin = input.int(1, "Line Thin", minval=1, maxval=4, group=groupVisual)
inLineNormal = input.int(2, "Line Normal", minval=1, maxval=6, group=groupVisual)
inLineBold = input.int(3, "Line Bold", minval=1, maxval=8, group=groupVisual)
inAlphaStrong = input.int(10, "Alpha Strong", minval=0, maxval=90, group=groupVisual)
inAlphaMedium = input.int(35, "Alpha Medium", minval=0, maxval=95, group=groupVisual)
inAlphaSoft = input.int(65, "Alpha Soft", minval=0, maxval=99, group=groupVisual)

// ----------------------------------------------------------------------------
// [C] Utility functions
// ----------------------------------------------------------------------------
fClamp(v, lo, hi) =>
    math.max(lo, math.min(hi, v))

fSafeDiv(a, b, eps) =>
    a / (math.abs(b) < eps ? eps : b)

fNorm(v, scale) =>
    fClamp(fSafeDiv(v, scale, 1e-6), -1.0, 1.0)

fNormRobust(v, center, spread, clampN) =>
    z = fSafeDiv(v - center, spread, 1e-6)
    fClamp(z / clampN, -1.0, 1.0)

fLineStyle(s) =>
    s == "Dashed" ? line.style_dashed : s == "Dotted" ? line.style_dotted : line.style_solid

fColorBull() =>
    inTheme == "Nebula" ? color.rgb(0, 255, 170) :
     inTheme == "Monochrome Pro" ? color.rgb(220, 220, 220) :
     inTheme == "SMC Tactical" ? color.rgb(80, 220, 120) : color.rgb(60, 255, 200)

fColorBear() =>
    inTheme == "Nebula" ? color.rgb(255, 90, 180) :
     inTheme == "Monochrome Pro" ? color.rgb(120, 120, 120) :
     inTheme == "SMC Tactical" ? color.rgb(255, 110, 110) : color.rgb(255, 120, 70)

fColorNeutral() =>
    inTheme == "Nebula" ? color.rgb(130, 150, 255) :
     inTheme == "Monochrome Pro" ? color.rgb(180, 180, 180) :
     inTheme == "SMC Tactical" ? color.rgb(180, 200, 120) : color.rgb(140, 170, 255)

fSignalText(s) =>
    s == SIG_LONG ? "LONG" : s == SIG_SHORT ? "SHORT" : "WAIT"

fRiskText(r) =>
    r == RISK_LOW ? "LOW" : r == RISK_MED ? "MED" : "HIGH"

fRegimeText(r) =>
    r == REGIME_TREND ? "TREND" : r == REGIME_RANGE ? "RANGE" : r == REGIME_VOLATILE ? "VOL" : "TRANS"

// ----------------------------------------------------------------------------
// [D] Generic array push helpers
// ----------------------------------------------------------------------------
fPushInt(arr, v, n) =>
    array.unshift(arr, v)
    if array.size(arr) > n
        array.pop(arr)

fPushFloat(arr, v, n) =>
    array.unshift(arr, v)
    if array.size(arr) > n
        array.pop(arr)

fPushString(arr, v, n) =>
    array.unshift(arr, v)
    if array.size(arr) > n
        array.pop(arr)

// ----------------------------------------------------------------------------
// [E] Runtime state (single-source declarations only)
// ----------------------------------------------------------------------------

