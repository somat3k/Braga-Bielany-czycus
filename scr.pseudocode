const string MODE_MULTI_ENSEMBLE = "MULTI_ENSEMBLE"
const string MODE_WEIGHTED = "WEIGHTED_ENSEMBLE"

const int SIG_LONG = 1
const int SIG_SHORT = -1
const int SIG_WAIT = 0

const int REGIME_TREND = 1
const int REGIME_RANGE = 2
const int REGIME_VOLATILE = 3
const int REGIME_TRANSITION = 4

