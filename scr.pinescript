// ----------------------------------------------------------------------------
// [C] Utility functions
// ----------------------------------------------------------------------------
fClamp(v, lo, hi) =>
    math.max(lo, math.min(hi, v))

fSafeDiv(a, b, eps) =>
    a / (math.abs(b) < eps ? eps : b)

fNorm(v, scale) =>
    fClamp(fSafeDiv(v, scale, 1e-6), -1.0, 1.0)

fNormRobust(v, center, spread, clampN) =>
    z = fSafeDiv(v - center, spread, 1e-6)
    fClamp(z / clampN, -1.0, 1.0)

fLineStyle(s) =>
    s == "Dashed" ? line.style_dashed : s == "Dotted" ? line.style_dotted : line.style_solid

fThemeBull() =>
    inTheme == "Nebula" ? color.rgb(0, 255, 170) :
     inTheme == "Monochrome Pro" ? color.rgb(220, 220, 220) :
     inTheme == "SMC Tactical" ? color.rgb(80, 220, 120) :
     inTheme == "Neon Dark" ? color.rgb(0, 220, 255) :
     inTheme == "Earth Tones" ? color.rgb(154, 184, 128) : color.rgb(60, 255, 200)

fThemeBear() =>
    inTheme == "Nebula" ? color.rgb(255, 90, 180) :
     inTheme == "Monochrome Pro" ? color.rgb(120, 120, 120) :
     inTheme == "SMC Tactical" ? color.rgb(255, 110, 110) :
     inTheme == "Neon Dark" ? color.rgb(255, 60, 180) :
     inTheme == "Earth Tones" ? color.rgb(184, 106, 72) : color.rgb(255, 120, 70)

fThemeNeutral() =>
    inTheme == "Nebula" ? color.rgb(130, 150, 255) :
     inTheme == "Monochrome Pro" ? color.rgb(180, 180, 180) :
     inTheme == "SMC Tactical" ? color.rgb(180, 200, 120) :
     inTheme == "Neon Dark" ? color.rgb(170, 170, 255) :
     inTheme == "Earth Tones" ? color.rgb(186, 168, 132) : color.rgb(140, 170, 255)

fColorBull() =>
    inUseLinePaletteOverrides ? inLineColBull : fThemeBull()

fColorBear() =>
    inUseLinePaletteOverrides ? inLineColBear : fThemeBear()

fColorNeutral() =>
    inUseLinePaletteOverrides ? inLineColNeutral : fThemeNeutral()

fColorFib() =>
    inLineColFib

fColorOB() =>
    inLineColOB

fColorFork() =>
    inLineColFork

fSignalText(s) =>
    s == SIG_LONG ? "LONG" : s == SIG_SHORT ? "SHORT" : "WAIT"

fRiskText(r) =>
    r == RISK_LOW ? "LOW" : r == RISK_MED ? "MED" : "HIGH"

fRegimeText(r) =>
    r == REGIME_TREND ? "TREND" : r == REGIME_RANGE ? "RANGE" : r == REGIME_VOLATILE ? "VOL" : "TRANS"

fConflictColor(cx) =>
    na(cx) ? color.white : cx > CONFLICT_HIGH ? fColorBear() : cx > CONFLICT_MED ? color.yellow : fColorBull()

// ----------------------------------------------------------------------------
// [D] Generic array push helpers
// ----------------------------------------------------------------------------
fPushInt(arr, v, n) =>
    array.unshift(arr, v)
    if array.size(arr) > n
        array.pop(arr)

fPushFloat(arr, v, n) =>
    array.unshift(arr, v)
    if array.size(arr) > n
        array.pop(arr)

fPushString(arr, v, n) =>
    array.unshift(arr, v)
    if array.size(arr) > n
        array.pop(arr)

